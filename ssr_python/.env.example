# Copy to .env and fill in values. NEVER commit .env
FLASK_ENV=development

# LLM Chat — RAG pipeline backend
# Pick one backend; leave API_KEY empty for local Ollama.
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# RAG generation model (see rag/config.py for defaults)
RAG_MODEL_BACKEND=ollama            # ollama | openai | anthropic | groq
RAG_MODEL_NAME=phi4-mini
RAG_OLLAMA_URL=http://localhost:11434

# Cloud backends (only needed if RAG_MODEL_BACKEND matches)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

# Image Search (at least one required)
PEXELS_API_KEY=
PIXABAY_API_KEY=
